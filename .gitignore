# ============================================================
#  SP — Fluidodinamica Computazionale dei Sistemi Propulsivi
#  .gitignore
# ============================================================

# --- LaTeX Temporary Files ---
*.aux
*.log
*.toc
*.synctex.gz
*.fdb_latexmk
*.fls
*.pdf
*.bbl
*.blg
*.lof
*.lot

# --- Fortran & Compilation ---
# Eseguibili
*.exe
*.app

# File oggetto e moduli Fortran
*.o
*.mod
*.smod

# Cartelle di output compilazione
bin/
obj/

# Eseguibile del solutore. Il pattern e' ancorato per non ignorare
# accidentalmente la directory Euler2D su filesystem case-insensitive.
/Euler2D/euler2d
/Euler2D/euler2d.exe

# --- Output solutore CFD ---
# File Tecplot ASCII (soluzioni, troppo grandi per il repo)
*.dat

# File Tecplot binari
*.plt

# Batch Euler2D/Bump: cartelle generate localmente dagli script.
Bump/runs/
Bump/RECAP_SIMULAZIONI.csv.legacy_*.bak
Bump/-p/


# --- Gmsh binary (installare da https://gmsh.info) ---
# Non committare l'eseguibile: è platform-specific e pesa ~80 MB
gmsh-*/

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
.env

# --- Julia ---
*.ji
.julia/

# --- Code::Blocks ---
*.cbp
*.layout
*.depend

# --- VS Code ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# --- Sistema Operativo ---
Thumbs.db
Desktop.ini
.DS_Store
*~
