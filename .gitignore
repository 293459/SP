# ============================================================
#  SP — Fluidodinamica Computazionale dei Sistemi Propulsivi
#  .gitignore
# ============================================================

# --- LaTeX Temporary Files ---
*.aux
*.log
*.toc
*.synctex.gz
*.fdb_latexmk
*.fls
*.pdf
*.bbl
*.blg
*.lof
*.lot

# --- Fortran & Compilation ---
# Eseguibili
*.exe
*.app

# File oggetto e moduli Fortran
*.o
*.mod
*.smod

# Cartelle di output compilazione
bin/
obj/

# Eseguibile del solutore
euler2d
euler2d.exe

# --- Output solutore CFD ---
# File Tecplot ASCII (soluzioni, troppo grandi per il repo)
*.dat

# File Tecplot binari
*.plt

# Mesh generate (rigenerare con: gmsh <file>.geo -2)
# NOTA: i file .geo (geometria sorgente) vanno invece committati
*.msh

# --- Gmsh binary (installare da https://gmsh.info) ---
# Non committare l'eseguibile: è platform-specific e pesa ~80 MB
gmsh-*/

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
.env

# --- Julia ---
*.ji
.julia/

# --- Code::Blocks ---
*.cbp
*.layout
*.depend

# --- VS Code ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# --- Sistema Operativo ---
Thumbs.db
Desktop.ini
.DS_Store
*~
