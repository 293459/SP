{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compila Paletta",
            "type": "shell",
            "command": "gfortran",
            "args": [
                "-g",
                "main.f90",
                "calcolo_area.f90",
                "calcolo_baricentro.f90",
                "-o",
                "bin/Debug/paletta.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}/3-Paletta"
            },
            "group": "build",
            "presentation": {
                "reveal": "always"
            }
        }
    ]
}