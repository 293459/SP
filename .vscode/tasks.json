{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Euler2D: clean",
            "type": "shell",
            "command": "mingw32-make",
            "args": ["clean"],
            "options": { "cwd": "${workspaceFolder}/Euler2D" },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Euler2D: build",
            "type": "shell",
            "command": "mingw32-make",
            "options": { "cwd": "${workspaceFolder}/Euler2D" },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Euler2D: clean + build",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Euler2D: clean",
                "Euler2D: build"
            ],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Euler2D: debug build",
            "type": "shell",
            "command": "mingw32-make",
            "args": ["debug"],
            "options": { "cwd": "${workspaceFolder}/Euler2D" },
            "group": "build",
            "problemMatcher": []
        }
    ]
}
