{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Paletta",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}\\3-Paletta\\bin\\Debug\\paletta.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}\\3-Paletta",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "${env:LOCALAPPDATA}\\Microsoft\\WinGet\\Links\\gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Compila Paletta"
        }
    ]
}
